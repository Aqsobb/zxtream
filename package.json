{
  "name": "zxtream",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"node node_modules/next/dist/bin/next dev\" \"node server/index.js\"",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next build && concurrently \"node node_modules/next/dist/bin/next start -p 3000\" \"node server/index.js\"",
    "start:backend": "node server/index.js",
    "start:frontend": "node node_modules/next/dist/bin/next start -p 3000",
    "cap:init": "npx cap init Z.XTREAM com.zxtream.app --web-dir out",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "cap:build": "cd android && ./gradlew assembleDebug",
    "apk": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "postinstall": "echo 'Install done'"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "autoprefixer": "^10.4.19",
    "axios": "^1.7.2",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase": "^10.12.0",
    "framer-motion": "^11.0.0",
    "hls.js": "^1.6.16",
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.2.1",
    "swiper": "^11.2.10",
    "tailwindcss": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.4.38",
    "typescript": "^5.4.0"
  }
}
